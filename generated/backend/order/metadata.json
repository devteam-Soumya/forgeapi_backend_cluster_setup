{
  "module_name": "order",
  "access_modes": [
    "public",
    "rbac"
  ],
  "template_keys": [
    "public_crud_api",
    "protected_rbac_api"
  ],
  "primary_mode": "rbac",
  "display_route": "/orders",
  "collection_name": "orders",
  "auth_enabled": true,
  "token_required": true,
  "rbac_enabled": true,
  "permissions": {
    "create": "create_order",
    "read": "read_order"
  },
  "fields": [
    {
      "name": "orderNumber",
      "type": "str",
      "required": true,
      "unique": true
    },
    {
      "name": "total",
      "type": "float",
      "required": true,
      "unique": false
    },
    {
      "name": "status",
      "type": "str",
      "required": true,
      "unique": false
    }
  ]
}